# Shop storefront origin (used by shop + rent). Rental app resolves `/uploads/...` against this.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# Optional: when rent is built/served with a different NEXT_PUBLIC_BASE_URL, set the shop URL here
# so product images still load from the shop host (CDN or primary domain is fine as long as it serves /uploads).
# NEXT_PUBLIC_SHOP_ORIGIN="https://shop.example.com"

# Relative paths are anchored to packages/db/prisma/ (see packages/db/src/sqliteDatabaseUrl.ts).
DATABASE_URL="file:./dev.db"
# Set to 1 only if you must bypass SQLite URL normalization (debug / unusual layouts).
# LUMIERE_SKIP_SQLITE_URL_NORMALIZE=1
# If Prisma cannot find the DB file (error 14), set absolute path to packages/db/prisma:
# LUMIERE_PRISMA_DIR="C:/AIapps/JewlleryEshop/packages/db/prisma"
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Production: set to absolute apps/shop/public under APP_DIR so uploads and `next start`
# serve the same files (never keep the live app only under /root — broken /uploads for others).
# SHOP_PUBLIC_DIR="/var/www/lumiere/apps/shop/public"
RENT_BASE_URL="http://localhost:3001"
ADMIN_USER="admin"
ADMIN_PASS="changeme"
# Random string >= 32 chars used to sign admin session cookies.
SESSION_SECRET="change-me-to-a-long-random-string-please"

# Twilio SMS notifications (optional)
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_FROM_NUMBER="+852..."

# Optional: deploy/sync-site.sh — full rsync destination (local path or user@host:/path)
# SYNC_TARGET="/mnt/vps/lumiere"
# SYNC_TARGET="deploy@203.0.113.10:/var/www/lumiere"
